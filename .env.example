# Environment Variables for EvoExplore

# MongoDB Configuration (Development - No Auth)
# For local development, use the start_dev_mongo.sh script
MONGODB_URI=mongodb://localhost:27017/evoexplore
MONGODB_DB=evoexplore

# Clerk Authentication (Optional - Keyless Mode)
# Clerk will auto-generate temporary keys if not provided
# To use production keys, get them from https://dashboard.clerk.com
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key_here
# CLERK_SECRET_KEY=your_clerk_secret_key_here

# Server Configuration
NEXT_PUBLIC_SERVER_URL=http://localhost:8080
NEXT_PUBLIC_WS_URL=ws://localhost:8080

# Game Configuration
NEXT_PUBLIC_MAX_PLAYERS_PER_SERVER=100
NEXT_PUBLIC_MAX_VISIBLE_PLAYERS=10
NEXT_PUBLIC_MAX_MOBS=150

# Development
NODE_ENV=development
